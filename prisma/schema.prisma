// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Item {
  id String @id @default(uuid())

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  name             String /// User Given Name of Item.
  description      String? /// User Given Description of Item.
  physicalLocation String? /// The physical location on campus where an item exists.
  placeOfPurchase  String? /// Where the item will be or was purchased from. 
  price            Float
  stockQuantity    Int        @default(0)
  status           ItemStatus @default(PENDING_APPROVAL) /// The status of the item.

  requestId String? /// The id of the request that the item is in.
  request   Request? @relation(fields: [requestId], references: [id]) /// The request that the item is in.
}

enum ItemStatus {
  PENDING_APPROVAL
  AWAITING_PURCHASE
  PURCHASED
  ON_CAMPUS
  DENIED
}

/// A pending, approved, or temrinated, bundle of items to be purchased. 
model Request {
  id           String        @id @default(uuid()) /// The id of the request.
  createdAt    DateTime      @default(now())
  name         String /// The name of the request. 
  purpose      String? /// The reason why the items in the request are needed.
  requestItems Item[] /// The items that are in the request.
  status       RequestStatus @default(NOT_SUBMITTED) /// Can be 'Pending', 'Denied', or 'Approved'.
  totalCost    Float         @default(0) /// The total cost of the request, calculated as the sum of the cost of all items in the request.

  ownerId String /// The id of the user who created the request.
  owner   User   @relation(name: "authoredRequests", fields: [ownerId], references: [id]) /// The user who created the request.

  // TODO: Add in a user entity for who approved the request.

  approvers User[] @relation(name: "approvedRequests") /// The users who approved the request.

  projectId String?
  project   Project? @relation(name: "projectRequests", fields: [projectId], references: [id]) /// The project this request belongs to.
}

/// Statuses of a request. 
enum RequestStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  DENIED
}

model Project {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  name   String
  budget Float  @default(0)

  requests  Request[] @relation(name: "projectRequests")
  approvers User[]    @relation("projectApprovers")
}
