// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// TODO: Add user model among other models described in CRC. I.E when Cooper is done with auth. 

// Notes from Nick:
// The Items and Requests are related implicitly many-to-many. We may need to make a 
// entire seperate model to explicitly define this relationship. Otherwise
// Prisma does not support certain database actions like On, Update, Cascade, etc. 
// Also I know there's probably ways to automate other aspects within the databse, 
// but I'm not sure enough in my understanding to attempt implementing these right now. 

/// A type of item that can be on campus or pending in a request. 
model Item {
  id Int @id @default(autoincrement())

  createdAt DateTime @default(now()) 

  name String @db.VarChar(100) /// User Given Name of Item.
  description String? @db.VarChar(300) /// User Given Description of Item.
  physicalLocation String? @db.VarChar(40) /// The physical location on campus where an item exists.
  placeOfPurchase String? @db.VarChar(100) /// Where the item will be or was purchased from. 

  quantity Int /// The amount of an item requested or existing. 
  // TODO: Verify if this is a good way of storing price.  
  price Decimal @db.Decimal(20, 2) /// The last known price of an item.

  requests Request[] /// The item can be in many different requests. 
}

/// A pending, approved, or temrinated, bundle of items to be purchased. 
model Request {
  id Int @id @default(autoincrement())
  createdAt DateTime @default(now())
  name String @db.VarChar(100) /// The name of the request. 
  purpose String? @db.VarChar(300) /// The reason why the items in the request are needed.

  // TODO: Add in a user entity for who created the request. 
  // TODO: Add in a user entity for who approved the request.

  // TODO: Verify if this is a good way to keep track of status. 
  status String /// Can be 'Pending', 'Terminated', or 'Approved'.
  // We can perhaps have a pending bool field instead. 

  // TODO: Verify if we should store this and if there's a way to automate it from items.  
  price Decimal @db.Decimal(20, 2) /// The last known price of an item.

  // TODO: Add in any more fields I'm blanking on. 


  items Item[] /// The items contained in the request. 
}
